# Copy to .env.local and fill in. Values come from the Supabase dashboard:
# Project Settings -> API.

# --- PUBLIC (browser-safe) ---
# Publishable/anon values. Safe to ship in the browser bundle; RLS protects the
# data. Must be prefixed NEXT_PUBLIC_ to be inlined at build time.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx

# --- SERVER-ONLY SECRETS ---
# NEVER prefix these with NEXT_PUBLIC_ and never commit real values. They run
# only in API routes and must also be set in Vercel's env vars.

# Supabase service-role key (bypasses RLS). Used by the Twilio inbound webhook
# and the authenticated send route. Treat like a password.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe secret key (card-on-file).
STRIPE_SECRET_KEY=sk_test_xxxxxxxx

# Twilio (SMS). The auth token also verifies the inbound webhook signature.
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# Optional — only if the inbound webhook URL can't be inferred from request
# headers. Must match the URL configured in Twilio.
# TWILIO_WEBHOOK_URL=https://threshold.salon/api/sms/inbound
